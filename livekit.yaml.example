# LiveKit Server configuration (development)
# Документация: https://docs.livekit.io/realtime/self-hosting/deployment/
# Скопируйте в livekit.yaml и заполните реальные значения.
port: 7880

rtc:
  tcp_port: 7881
  port_range_start: 7100
  port_range_end: 7110
  # use_external_ip: true определяет внешний IP через STUN.
  # Если STUN возвращает IP NAT-шлюза, а не IP сервера,
  # задайте node_ip явно. Должен совпадать с DNS-записью.
  use_external_ip: false
  node_ip: YOUR_SERVER_PUBLIC_IP

keys:
  YOUR_LIVEKIT_API_KEY: YOUR_LIVEKIT_API_SECRET

# TURN позволяет WebRTC-трафику пробиться через строгие NAT/файрволы,
# маскируясь под обычный TCP/TLS. В dev-режиме не нужен.
# turn:
#   enabled: true
#   tls_port: 5349
#   udp_port: 3478

logging:
  level: info
