# ── Application ──────────────────────────────
APP_NAME=Julow
APP_VERSION=0.1.0
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_PREFIX=/api/v1

# ── Database ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=julow
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_ECHO=false

# ── Authentication ───────────────────────────
AUTH_JWT_SECRET_KEY=change-me-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DEFAULT_TTL=3600

# ── S3 (MinIO / AWS S3) ──────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=julow
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRES=3600

# ── ClamAV (антивирус для FileStorage BC) ───
# Если CLAMAV_ENABLED=false — используется NoOpScannerAdapter
# (всегда CLEAN, для локальной разработки/тестов).
# В production обязательно включить + поднять контейнер `clamav/clamav`.
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=60
CLAMAV_CHUNK_SIZE_BYTES=1048576
CLAMAV_BLOCK_PENDING_DOWNLOADS=true

# ── Kafka ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=julow-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

# ── SMTP ──────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@julow.com

# ── Celery ────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ntfy (Push) ───────────────────────────────
NTFY_BASE_URL=https://ntfy.sh
NTFY_DEFAULT_TOPIC=julow

# ── OAuth ────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ── Encryption (Fernet) ─────────────────────
ENCRYPTION_KEY=AAmioAjwB55kaBoOrZYZHrbnv21GCNdcPAxCgwJDs8s=

# ── CORS ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=["*"]
CORS_ALLOWED_HEADERS=["*"]
