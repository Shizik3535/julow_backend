# =============================================================================
#  Julow Backend — Environment Variables
# =============================================================================
#  Скопируйте в `.env` для локального запуска (без Docker) или передайте
#  через docker-compose / Kubernetes secrets / systemd service.
# =============================================================================


# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Julow
APP_VERSION=0.1.0
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_PREFIX=/api/v1

#
# Базовый URL backend (используется для генерации absolute-ссылок,
# например в email confirmation / password reset / OAuth state callbacks).
# Должен совпадать с тем, как backend доступен извне.
#
APP_BASE_URL=http://localhost:8000

#
# Базовый URL frontend (используется для генерации redirect_uri в OAuth
# флоу, email-линков и CORS-настройки). В production обязательно меняйте.
#
FRONTEND_BASE_URL=http://localhost:3000


# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=julow
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
# В production — DB_ECHO=false. true только для отладки SQL.
DB_ECHO=false


# ─── Authentication / JWT ─────────────────────────────────────────────────────
#
# ОБЯЗАТЕЛЬНО смените в production. Сгенерируйте через:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#
AUTH_JWT_SECRET_KEY=change-me-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7


# ─── Redis (кеш + Celery broker + WS pub/sub) ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DEFAULT_TTL=3600


# ─── S3 / MinIO (FileStorage BC) ──────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=julow
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRES=3600


# ─── ClamAV (антивирус для FileStorage BC) ───────────────────────────────────
#
# Если CLAMAV_ENABLED=false — используется NoOpScannerAdapter (всегда CLEAN,
# для dev/тестов). В production ОБЯЗАТЕЛЬНО включить + поднять контейнер
# `clamav/clamav` (см. docker-compose.yml).
#
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=60
CLAMAV_CHUNK_SIZE_BYTES=1048576
CLAMAV_BLOCK_PENDING_DOWNLOADS=true


# ─── Kafka (event bus для inter-BC коммуникации) ─────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=julow-consumer
KAFKA_AUTO_OFFSET_RESET=earliest


# ─── SMTP (email confirmation, password reset) ────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@julow.com


# ─── Celery (фоновые задачи) ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2


# ─── ntfy (Push-уведомления) ──────────────────────────────────────────────────
NTFY_BASE_URL=https://ntfy.sh
NTFY_DEFAULT_TOPIC=julow


# ─── OAuth (Google / GitHub) ──────────────────────────────────────────────────
#
#  Как получить:
#
#  ▸ Google:  https://console.cloud.google.com/apis/credentials
#     1. Create Credentials → OAuth 2.0 Client ID → Web application
#     2. Authorized redirect URIs:
#        http://localhost:3000/oauth/callback         (dev)
#        https://app.julow.example.com/oauth/callback  (prod)
#     3. Скопируйте Client ID + Client Secret сюда.
#
#  ▸ GitHub:  https://github.com/settings/developers
#     1. New OAuth App
#     2. Authorization callback URL:
#        http://localhost:3000/oauth/callback         (dev)
#        https://app.julow.example.com/oauth/callback  (prod)
#     3. Скопируйте Client ID + сгенерируйте новый Client Secret.
#
#  Важно: `redirect_uri` ДОЛЖЕН точно совпадать с тем, что прописан в
#  консоли провайдера. По умолчанию frontend использует:
#  `${FRONTEND_BASE_URL}/oauth/callback`. См. julow-web/.env.example.
#
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=


# ─── Encryption (Fernet — шифрование чувствительных полей в БД) ───────────────
#
# Сгенерируйте новый ключ для production:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# ⚠️ ПОТЕРЯ КЛЮЧА = ПОТЕРЯ ДОСТУПА К ЗАШИФРОВАННЫМ ДАННЫМ. Бэкапьте надёжно.
#
ENCRYPTION_KEY=AAmioAjwB55kaBoOrZYZHrbnv21GCNdcPAxCgwJDs8s=


# ─── CORS ─────────────────────────────────────────────────────────────────────
#
# В production — НИКОГДА не используйте `["*"]`. Перечислите конкретные
# origin'ы frontend'а:
#   CORS_ALLOWED_ORIGINS=["https://app.julow.example.com","https://admin.julow.example.com"]
#
# CORS_ALLOW_CREDENTIALS=true НЕОБХОДИМ для cookie-based авторизации
# (наш auth работает на HTTP-only refresh-cookie + Bearer access-token).
#
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOWED_HEADERS=["*"]
